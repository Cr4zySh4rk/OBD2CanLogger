{
  "name": "obd2-can-logger",
  "productName": "OBD2 CAN Logger",
  "version": "1.0.0",
  "description": "Offline desktop app for OBD2 CAN logging and engine map reconstruction",
  "main": "src/main.js",
  "author": "Cr4zySh4rk",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac   --config electron-builder.json",
    "build:win": "electron-builder --win   --config electron-builder.json",
    "build:linux": "electron-builder --linux --config electron-builder.json",
    "build:all": "electron-builder --mac --win --linux --config electron-builder.json"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3"
  }
}
